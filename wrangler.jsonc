{
	"compatibility_date": "2026-04-03",
	"compatibility_flags": ["global_fetch_strictly_public", "nodejs_compat"],
	"name": "mikrom-docs",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	},
  "router": [
    {
      "pattern": "docs.mikrom.es",
      "custom_domain": true
    }
  ]
}
